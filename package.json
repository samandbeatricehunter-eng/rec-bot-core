{
  "name": "rec-bot-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:api": "pnpm --filter @rec/api dev",
    "dev:bot": "pnpm --filter @rec/bot dev",
    "build": "node scripts/railway-build.mjs",
    "build:all": "pnpm -r build",
    "build:site": "pnpm --filter @rec/shared build && pnpm --filter @rec/site build",
    "start": "node scripts/railway-start.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "tesseract.js"]
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
