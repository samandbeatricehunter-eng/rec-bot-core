# Baked into the client bundle at build time (Vite convention: must be VITE_-prefixed).
# This is the ANON/PUBLISHABLE key, not the service role key — safe to expose client-side.
# Both values come from the Supabase project settings (API section).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_REC_CORE_API_URL=http://localhost:3000
# Public origin of this site (used for auth emailRedirectTo). Prod example: https://rec-leagues.com
VITE_SITE_URL=http://localhost:5174
# Checkout/portal return URLs use window.location.origin (no extra env vars).
