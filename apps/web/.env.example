# Baked into the client bundle at build time (Vite convention: must be VITE_-prefixed).
VITE_DISCORD_CLIENT_ID=
# The URL-Mapping-proxied API prefix Discord routes this Activity's calls through
# (e.g. "/api"), not the raw apps/api Railway URL — set once URL Mappings are configured
# in the Developer Portal.
VITE_REC_CORE_API_URL=
