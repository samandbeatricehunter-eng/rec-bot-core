# Baked into the client bundle at build time (Vite convention: must be VITE_-prefixed).
# The real, public URL of the apps/api Railway service (e.g. "https://api-production-xxxx.up.railway.app") —
# this is a normal cross-origin fetch, not a Discord Activity proxy, so no path-prefix trick is needed.
VITE_REC_CORE_API_URL=
# Public REC Leagues site — used when someone opens the Discord hub URL without a /app token.
VITE_SITE_PUBLIC_URL=https://rec-leagues.com
